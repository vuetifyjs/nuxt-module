{
  "name": "vuetify-nuxt-module-workspace",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "version": "1.0.0-beta.1",
  "scripts": {
    "prepack": "pnpm -C packages/vuetify-nuxt-module prepack",
    "dev": "pnpm -C apps/playground dev",
    "dev:multiple-json": "MULTIPLE_LANG_FILES=true pnpm -C apps/playground dev",
    "dev:prepare": "pnpm -C packages/vuetify-nuxt-module dev:prepare",
    "dev:prepare:multiple-json": "pnpm -C packages/vuetify-nuxt-module dev:prepare:multiple-json",
    "dev:build": "pnpm -C apps/playground build",
    "dev:generate": "pnpm -C apps/playground generate",
    "dev:build:multiple-json": "MULTIPLE_LANG_FILES=true pnpm -C apps/playground build",
    "dev:generate:multiple-json": "MULTIPLE_LANG_FILES=true pnpm -C apps/playground generate",
    "dev:preview": "pnpm -C apps/playground preview",
    "dev:prepare:date-io": "pnpm -C packages/vuetify-nuxt-module dev:prepare:date-io",
    "dev:date-io": "pnpm -C apps/date-io-playground dev",
    "docs:dev": "pnpm -C docs run dev",
    "docs:build": "pnpm -C packages/vuetify-nuxt-module docs:build",
    "docs:serve": "pnpm -C packages/vuetify-nuxt-module docs:serve",
    "lint": "pnpm -C packages/vuetify-nuxt-module lint",
    "lint:fix": "pnpm -C packages/vuetify-nuxt-module lint:fix",
    "publint": "pnpm -C packages/vuetify-nuxt-module publint",
    "test": "pnpm -C packages/vuetify-nuxt-module test",
    "test:watch": "pnpm -C packages/vuetify-nuxt-module test:watch",
    "release": "bumpp -r"
  },
  "devDependencies": {
    "bumpp": "catalog:",
    "eslint": "catalog:",
    "eslint-config-vuetify": "catalog:"
  }
}
